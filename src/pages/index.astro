---
export const prerender = true;

import { getCollection } from "astro:content";
import DefaultPageLayout from "$/layouts/default.astro";
import PostPreviewList from "$/components/PostPreviewList.astro";
import { Content as AboutAstroInk } from "./_home_intro.md";

const title = "Home";
const description = "Daily News Report - Your daily dose of tech and development news";

let posts = await getCollection("blog");
posts = posts.sort((a, b) => new Date(b.data.date) - new Date(a.data.date));

// Get latest 8 posts
const latestPosts = posts.slice(0, 8);

// Get unique categories from tags
const allTags = posts.flatMap(post => post.data.tags || []);
const uniqueCategories = [...new Set(allTags)].slice(0, 8);
---

<DefaultPageLayout content={{ title, description }} showPageHeader={false}>
  <!-- Hero Section with Featured Article -->
  <section class="hero-section">
    <div class="hero-content">
      <h1 class="hero-title font-display font-bold">
        <span class="title-line">Daily News</span>
        <span class="title-line title-accent">Report</span>
      </h1>
      <p class="hero-description">
        你的每日科技新闻精选，AI 驱动的智能聚合
      </p>
    </div>

    <!-- Category Pills -->
    <div class="category-pills">
      {uniqueCategories.map(category => (
        <a
          href={`/tags/${category}`}
          class="category-pill"
        >
          {category}
        </a>
      ))}
    </div>
  </section>

  <!-- Featured Posts Section -->
  <section class="featured-section">
    <PostPreviewList
      posts={latestPosts}
      mode="col"
      showFeatured={true}
      featuredCount={1}
      heading="Latest Stories"
    />
  </section>

  <!-- More Posts Grid -->
  <section class="more-posts-section">
    <div class="section-header">
      <h2 class="section-title">More Articles</h2>
      <a href="/blog" class="view-all-link">
        View All
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>

    <div class="posts-grid">
      {latestPosts.slice(1, 7).map((post, index) => (
        <article class={`post-card animate-fade-in-up stagger-${index + 1}`}>
          <a href={`/blog/${post.slug}`} class="post-card-link">
            {post.data.image ? (
              <div class="post-card-image img-zoom-container aspect-[16/10] overflow-hidden rounded-lg">
                <img
                  src={post.data.image}
                  alt={post.data.title}
                  class="w-full h-full object-cover"
                  loading="lazy"
                />
              </div>
            ) : (
              <div class="post-card-image aspect-[16/10] overflow-hidden rounded-lg bg-gradient-to-br from-theme-surface to-theme-surface2 flex items-center justify-center">
                <span class="text-4xl font-display font-bold text-theme-border/30">
                  {new Date(post.data.date).getDate()}
                </span>
              </div>
            )}

            <div class="post-card-content">
              {post.data.tags && post.data.tags.length > 0 && (
                <span class="post-card-category">
                  {post.data.tags[0]}
                </span>
              )}

              <h3 class="post-card-title font-display font-semibold line-clamp-2">
                {post.data.title}
              </h3>

              <p class="post-card-description text-sm line-clamp-2">
                {post.data.description}
              </p>

              <div class="post-card-meta">
                <time datetime={post.data.date}>
                  {new Date(post.data.date).toLocaleDateString('zh-CN', {
                    year: 'numeric',
                    month: 'long',
                    day: 'numeric'
                  })}
                </time>
              </div>
            </div>
          </a>
        </article>
      ))}
    </div>
  </section>

  <!-- CTA Section -->
  <section class="cta-section">
    <div class="cta-content">
      <h2 class="cta-title font-display font-bold">
        Stay Updated
      </h2>
      <p class="cta-description">
        Get the latest tech news delivered to your inbox daily
      </p>
      <div class="cta-actions">
        <a href="/blog" class="cta-button cta-button-primary">
          Browse All Posts
        </a>
        <a href="/tags" class="cta-button cta-button-secondary">
          Explore by Topic
        </a>
      </div>
    </div>
  </section>
</DefaultPageLayout>

<style>
  /* Hero Section */
  .hero-section {
    @apply py-12 md:py-20 lg:py-24;
    @apply text-center;
    @apply relative overflow-hidden;
  }

  .hero-section::before {
    content: '';
    @apply absolute inset-0;
    background: radial-gradient(ellipse at center, rgba(91, 124, 153, 0.08) 0%, transparent 70%);
    @apply pointer-events-none;
  }

  :global(html.dark) .hero-section::before {
    background: radial-gradient(ellipse at center, rgba(107, 184, 184, 0.1) 0%, transparent 70%);
  }

  .hero-content {
    @apply relative z-10;
  }

  .hero-title {
    @apply text-5xl md:text-7xl lg:text-8xl;
    @apply mb-6;
    @apply leading-tight;
  }

  .title-line {
    @apply block;
    @apply text-theme-text-primary;
  }

  .title-accent {
    @apply text-transparent bg-clip-text;
    background-image: linear-gradient(135deg, #5b7c99 0%, #6bb8b8 100%);
  }

  :global(html.dark) .title-accent {
    background-image: linear-gradient(135deg, #6bb8b8 0%, #d4a5a5 100%);
  }

  .hero-description {
    @apply text-lg md:text-xl text-theme-text-secondary;
    @apply max-w-2xl mx-auto;
    @apply mt-6;
  }

  /* Category Pills */
  .category-pills {
    @apply flex flex-wrap justify-center gap-3;
    @apply mt-10;
  }

  .category-pill {
    @apply px-4 py-2 rounded-full;
    @apply text-sm font-medium;
    @apply bg-theme-surface border border-theme-border;
    @apply text-theme-text-secondary;
    @apply transition-all duration-200 ease-out;
    @apply hover:border-theme-primary hover:text-theme-primary hover:bg-theme-primary/10;
  }

  :global(html.dark) .category-pill {
    @apply bg-theme-dark-surface border-theme-dark-border text-theme-dark-text-secondary;
    @apply hover:border-theme-dark-primary hover:text-theme-dark-primary hover:bg-theme-dark-primary/10;
  }

  /* Featured Section */
  .featured-section {
    @apply py-8;
  }

  /* More Posts Section */
  .more-posts-section {
    @apply py-12 md:py-16;
  }

  .section-header {
    @apply flex items-center justify-between;
    @apply mb-8;
  }

  .section-title {
    @apply text-2xl md:text-3xl font-display font-bold;
    @apply text-theme-text-primary;
  }

  :global(html.dark) .section-title {
    @apply text-theme-dark-text-primary;
  }

  .view-all-link {
    @apply inline-flex items-center gap-2;
    @apply text-theme-primary font-medium;
    @apply transition-all duration-200 ease-out;
    @apply hover:gap-3;
  }

  :global(html.dark) .view-all-link {
    @apply text-theme-dark-primary;
  }

  .posts-grid {
    @apply grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6;
  }

  .post-card {
    @apply bg-theme-surface rounded-xl overflow-hidden;
    @apply border border-theme-border;
    transition: all 0.3s ease-out;
  }

  :global(html.dark) .post-card {
    @apply bg-theme-dark-surface border-theme-dark-border;
  }

  .post-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1);
  }

  :global(html.dark) .post-card:hover {
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
  }

  .post-card-link {
    @apply block h-full;
  }

  .post-card-image {
    @apply w-full;
  }

  .post-card-content {
    @apply p-5;
  }

  .post-card-category {
    @apply inline-block;
    @apply px-3 py-1 rounded-full text-xs font-semibold uppercase tracking-wider;
    @apply bg-theme-primary/10 text-theme-primary;
    @apply mb-3;
  }

  :global(html.dark) .post-card-category {
    @apply bg-theme-dark-primary/20 text-theme-dark-primary;
  }

  .post-card-title {
    @apply text-lg text-theme-text-primary;
    @apply mb-2;
    @apply line-clamp-2;
  }

  :global(html.dark) .post-card-title {
    @apply text-theme-dark-text-primary;
  }

  .post-card-description {
    @apply text-theme-text-secondary;
    @apply mb-4;
  }

  :global(html.dark) .post-card-description {
    @apply text-theme-dark-text-secondary;
  }

  .post-card-meta {
    @apply text-xs text-theme-text-muted;
    @apply flex items-center gap-2;
  }

  :global(html.dark) .post-card-meta {
    @apply text-theme-dark-text-muted;
  }

  /* CTA Section */
  .cta-section {
    @apply py-16 md:py-24;
    @apply mt-12;
    @apply relative;
    @apply overflow-hidden;
    @apply rounded-2xl;
    background: linear-gradient(135deg, rgba(91, 124, 153, 0.1) 0%, rgba(107, 184, 184, 0.1) 100%);
    border: 1px solid rgba(91, 124, 153, 0.2);
  }

  :global(html.dark) .cta-section {
    background: linear-gradient(135deg, rgba(107, 184, 184, 0.12) 0%, rgba(212, 165, 165, 0.12) 100%);
    border: 1px solid rgba(107, 184, 184, 0.25);
  }

  .cta-content {
    @apply text-center px-6;
    @apply relative z-10;
  }

  .cta-title {
    @apply text-3xl md:text-4xl lg:text-5xl;
    @apply text-theme-text-primary;
    @apply mb-4;
  }

  :global(html.dark) .cta-title {
    @apply text-theme-dark-text-primary;
  }

  .cta-description {
    @apply text-lg text-theme-text-secondary;
    @apply max-w-xl mx-auto;
    @apply mb-8;
  }

  :global(html.dark) .cta-description {
    @apply text-theme-dark-text-secondary;
  }

  .cta-actions {
    @apply flex flex-wrap justify-center gap-4;
  }

  .cta-button {
    @apply px-6 py-3 rounded-full;
    @apply font-semibold;
    @apply transition-all duration-200 ease-out;
    @apply inline-flex items-center gap-2;
  }

  .cta-button-primary {
    @apply bg-theme-primary text-black;
    @apply hover:bg-theme-primary/90 hover:shadow-lg;
    @apply hover:-translate-y-0.5;
  }

  :global(html.dark) .cta-button-primary {
    @apply bg-theme-dark-primary hover:bg-theme-dark-primary/90;
  }

  .cta-button-secondary {
    @apply bg-theme-surface border border-theme-border text-theme-text-primary;
    @apply hover:border-theme-primary hover:text-theme-primary;
    @apply hover:bg-theme-primary/10;
  }

  :global(html.dark) .cta-button-secondary {
    @apply bg-theme-dark-surface border-theme-dark-border text-theme-dark-text-primary;
    @apply hover:border-theme-dark-primary hover:text-theme-dark-primary;
    @apply hover:bg-theme-dark-primary/10;
  }
</style>
