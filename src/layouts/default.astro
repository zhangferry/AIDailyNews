---
import { SITE } from '$/config'
import BaseHead from '$/components/BaseHead.astro';
import MainLayout from '$/components/MainLayout.astro';

const { content, showPageHeader = true } = Astro.props
---
<!doctype html>
<html lang="en">
    <head>
        <BaseHead title={ content.title ? `${ SITE.title } | ${content.title}` : SITE.title } description={ content.description } image={SITE.image}/>
    </head>
    <MainLayout>
        {showPageHeader &&
            <div class="page-header">
                <h1 class="page-title font-display">{content.title}</h1>
                {content.description && (
                    <p class="page-desc">{content.description}</p>
                )}
            </div>
        }
        <slot />
    </MainLayout>
</html>
<style>
    .page-header {
        @apply pt-8 pb-6 mb-4;
        @apply border-b;
        border-color: theme('colors.theme.border');
    }

    :global(html.dark) .page-header {
        border-color: theme('colors.theme.dark-border');
    }

    .page-title {
        @apply text-3xl md:text-4xl font-bold;
        @apply text-theme-text-primary;
        letter-spacing: -0.01em;
    }

    :global(html.dark) .page-title {
        @apply text-theme-dark-text-primary;
    }

    .page-desc {
        @apply mt-2 text-theme-text-muted;
    }

    :global(html.dark) .page-desc {
        @apply text-theme-dark-text-muted;
    }
</style>
