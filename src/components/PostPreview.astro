---
import type { CollectionEntry } from "astro:content";
import { getMonthName } from "$/utils";

interface Props {
  post: CollectionEntry<"blog">;
  asCard?: boolean;
  featured?: boolean;
}

const {
  post: { data: post, slug },
  asCard = false,
  featured = false,
} = Astro.props;

const { tags, date } = post;
const postDate = new Date(date);
const day = postDate.getDate();
const monthYear = `${getMonthName(date)} ${postDate.getFullYear()}`;
const category = tags && tags.length > 0 ? tags[0] : null;
---

<article class={`post-preview group ${featured ? 'post-preview--featured' : ''}`}>
  {featured ? (
    <a href={`/blog/${slug}`} class="featured-link">
      <div class="featured-meta">
        {category && <span class="featured-cat">{category}</span>}
        <time datetime={date}>{monthYear}</time>
      </div>
      <h2 class="featured-title font-display">{post.title}</h2>
      {post.description && (
        <p class="featured-desc">{post.description}</p>
      )}
    </a>
  ) : (
    <a href={`/blog/${slug}`} class="list-link">
      <div class="list-date">
        <span class="list-day font-display">{day}</span>
        <span class="list-month">{monthYear}</span>
      </div>
      <div class="list-content">
        <h3 class="list-title font-display">{post.title}</h3>
        {post.description && (
          <p class="list-desc">{post.description}</p>
        )}
        <div class="list-tags">
          {category && <span class="list-cat">{category}</span>}
          {tags && tags.length > 1 && tags.slice(1, 3).map(tag => (
            <span class="list-tag">#{tag}</span>
          ))}
        </div>
      </div>
    </a>
  )}
</article>

<style>
  /* Featured */
  .featured-link {
    @apply block;
    @apply transition-all duration-200;
    text-decoration: none;
  }

  .featured-meta {
    @apply flex items-center gap-3 mb-3;
    @apply text-xs text-theme-text-muted;
  }

  :global(html.dark) .featured-meta {
    @apply text-theme-dark-text-muted;
  }

  .featured-cat {
    @apply uppercase tracking-wider;
    @apply text-theme-text-secondary;
  }

  :global(html.dark) .featured-cat {
    @apply text-theme-dark-text-secondary;
  }

  .featured-title {
    @apply text-3xl md:text-4xl lg:text-5xl;
    @apply font-bold;
    @apply text-theme-text-primary;
    @apply leading-tight;
    @apply transition-colors duration-200;
    letter-spacing: -0.02em;
  }

  :global(html.dark) .featured-title {
    @apply text-theme-dark-text-primary;
  }

  .featured-link:hover .featured-title {
    @apply text-blue-500;
  }

  :global(html.dark) .featured-link:hover .featured-title {
    @apply text-blue-400;
  }

  .featured-desc {
    @apply text-base text-theme-text-secondary mt-3;
    @apply max-w-2xl line-clamp-2;
  }

  :global(html.dark) .featured-desc {
    @apply text-theme-dark-text-secondary;
  }

  /* List */
  .list-link {
    @apply flex items-start gap-5 md:gap-8;
    @apply py-5 md:py-6;
    @apply border-b;
    @apply transition-all duration-200;
    border-color: theme('colors.theme.border');
    text-decoration: none;
  }

  :global(html.dark) .list-link {
    border-color: theme('colors.theme.dark-border');
  }

  .list-link:last-child {
    @apply border-b-0;
  }

  .list-link:hover {
    padding-left: 6px;
  }

  .list-date {
    @apply flex-shrink-0 text-center;
    min-width: 48px;
  }

  .list-day {
    @apply text-2xl md:text-3xl font-bold;
    @apply text-theme-text-primary;
    line-height: 1;
  }

  :global(html.dark) .list-day {
    @apply text-theme-dark-text-primary;
  }

  .list-month {
    @apply text-[10px] text-theme-text-muted uppercase tracking-wider mt-1 block;
  }

  :global(html.dark) .list-month {
    @apply text-theme-dark-text-muted;
  }

  .list-content {
    @apply flex-1 min-w-0;
  }

  .list-title {
    @apply text-lg md:text-xl;
    @apply font-semibold;
    @apply text-theme-text-primary;
    @apply leading-snug line-clamp-2;
    @apply transition-colors duration-200;
  }

  :global(html.dark) .list-title {
    @apply text-theme-dark-text-primary;
  }

  .list-link:hover .list-title {
    @apply text-blue-500;
  }

  :global(html.dark) .list-link:hover .list-title {
    @apply text-blue-400;
  }

  .list-desc {
    @apply text-sm text-theme-text-secondary mt-1 line-clamp-1;
  }

  :global(html.dark) .list-desc {
    @apply text-theme-dark-text-secondary;
  }

  .list-tags {
    @apply flex items-center gap-3 mt-2;
  }

  .list-cat {
    @apply text-[10px] uppercase tracking-wider;
    @apply text-theme-text-secondary;
  }

  :global(html.dark) .list-cat {
    @apply text-theme-dark-text-secondary;
  }

  .list-tag {
    @apply text-xs text-theme-text-muted;
  }

  :global(html.dark) .list-tag {
    @apply text-theme-dark-text-muted;
  }
</style>
