<body class="font-sans antialiased min-h-screen bg-theme-background text-theme-text-primary dark:bg-theme-dark-background dark:text-theme-dark-text-primary">
  <!-- Decorative background elements -->
  <div class="fixed inset-0 -z-10 overflow-hidden pointer-events-none">
    <!-- Gradient orbs -->
    <div class="gradient-orb gradient-orb-1"></div>
    <div class="gradient-orb gradient-orb-2"></div>
    <div class="gradient-orb gradient-orb-3"></div>

    <!-- Grid pattern overlay -->
    <div class="grid-pattern"></div>
  </div>

  <div class="transition-colors relative z-10">
    <main class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <slot />
    </main>
  </div>
</body>

<style>
  /* Gradient orbs - light mode */
  .gradient-orb {
    @apply absolute rounded-full blur-3xl;
    @apply opacity-10 animate-pulse;
  }

  .gradient-orb-1 {
    @apply w-96 h-96;
    background: rgba(91, 124, 153, 0.15);
    @apply -top-48 -left-48;
    animation-duration: 8s;
  }

  .gradient-orb-2 {
    @apply w-80 h-80;
    background: rgba(125, 168, 123, 0.12);
    @apply top-1/2 -right-40;
    animation-duration: 10s;
  }

  .gradient-orb-3 {
    @apply w-64 h-64;
    background: rgba(212, 165, 165, 0.12);
    @apply -bottom-32 left-1/4;
    animation-duration: 12s;
  }

  /* Dark mode gradient orbs */
  :global(html.dark) .gradient-orb-1 {
    background: rgba(107, 184, 184, 0.15);
  }

  :global(html.dark) .gradient-orb-2 {
    background: rgba(212, 165, 165, 0.12);
  }

  :global(html.dark) .gradient-orb-3 {
    background: rgba(216, 184, 160, 0.12);
  }

  :global(html.dark) .gradient-orb {
    @apply opacity-15;
  }

  /* Grid pattern */
  .grid-pattern {
    @apply absolute inset-0;
    background-image:
      linear-gradient(to right, theme('colors.theme.border') 1px, transparent 1px),
      linear-gradient(to bottom, theme('colors.theme.border') 1px, transparent 1px);
    background-size: 60px 60px;
    opacity: 0.15;
    mask-image: radial-gradient(ellipse at center, black 10%, transparent 70%);
  }

  /* Dark mode adjustments */
  :global(html.dark) .grid-pattern {
    opacity: 0.1;
  }

  /* Responsive adjustments */
  @media (max-width: 768px) {
    .gradient-orb {
      @apply w-64 h-64;
    }
  }
</style>
