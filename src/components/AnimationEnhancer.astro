---
// Subtle animation and interaction enhancements
---

<div id="animation-enhancer" data-enabled></div>

<script>
  // Smooth scroll for anchor links
  document.querySelectorAll('a[href^="#"]').forEach(anchor => {
    anchor.addEventListener('click', function (e) {
      const href = this.getAttribute('href');
      if (!href || href === '#') return;

      const target = document.querySelector(href);
      if (target) {
        e.preventDefault();
        target.scrollIntoView({
          behavior: 'smooth',
          block: 'start'
        });
      }
    });
  });

  // Intersection Observer for scroll-triggered animations
  const observerOptions = {
    root: null,
    rootMargin: '0px',
    threshold: 0.1
  };

  const animationObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('animate-visible');
        animationObserver.unobserve(entry.target);
      }
    });
  }, observerOptions);

  function observeElements() {
    document.querySelectorAll('.animate-fade-in-up').forEach(el => {
      animationObserver.observe(el);
    });
  }

  document.addEventListener('astro:page-load', observeElements);
  observeElements();
</script>

<style>
  /* Scroll-triggered animation visibility */
  .animate-fade-in-up.animate-visible {
    animation: fadeInUp 0.5s ease-out forwards;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(12px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Smooth transitions for theme changes */
  * {
    @apply transition-colors duration-200 ease-out;
  }

  img,
  video,
  .no-transition {
    @apply transition-none;
  }

  /* Custom scrollbar */
  ::-webkit-scrollbar {
    @apply w-1.5;
  }

  ::-webkit-scrollbar-track {
    background: transparent;
  }

  ::-webkit-scrollbar-thumb {
    @apply bg-theme-border/40 rounded-full;
  }

  :global(html.dark) ::-webkit-scrollbar-thumb {
    @apply bg-theme-dark-border/40;
  }

  /* Selection color */
  ::selection {
    @apply bg-theme-primary/15 text-theme-primary;
  }

  :global(html.dark) ::selection {
    @apply bg-theme-dark-primary/15 text-theme-dark-primary;
  }

  ::-moz-selection {
    @apply bg-theme-primary/15 text-theme-primary;
  }

  :global(html.dark) ::-moz-selection {
    @apply bg-theme-dark-primary/15 text-theme-dark-primary;
  }

  /* Focus styles */
  a:focus-visible,
  button:focus-visible {
    @apply outline-2 outline-offset-2 outline-theme-primary;
    @apply rounded;
  }

  :global(html.dark) a:focus-visible,
  :global(html.dark) button:focus-visible {
    @apply outline-theme-dark-primary;
  }

  /* Reduce motion for users who prefer it */
  @media (prefers-reduced-motion: reduce) {
    *,
    *::before,
    *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
    }
  }
</style>
