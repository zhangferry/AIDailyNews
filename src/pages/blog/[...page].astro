---
export const prerender = true;

import { getCollection } from "astro:content";
import DefaultPageLayout from "$/layouts/default.astro";
import PostPreviewList from "$/components/PostPreviewList.astro";
import PostPreview from "$/components/PostPreview.astro";
import Paginator from "$/components/Paginator.astro";
import { PAGE_SIZE } from "$/config";

let title = "Blog";
let description = "所有文章和每日新闻报道";

export async function getStaticPaths({ paginate }) {
  const allPosts = await getCollection("blog");
  const sortedPosts = allPosts.toSorted(
    (a, b) => new Date(b.data.date) - new Date(a.data.date)
  );

  return paginate(sortedPosts, {
    pageSize: PAGE_SIZE,
  });
}

const { page } = Astro.props;
const posts = page.data;

const allPosts = await getCollection("blog");
const allTags = allPosts.flatMap(post => post.data.tags || []);
const uniqueCategories = [...new Set(allTags)].slice(0, 12);
---

<DefaultPageLayout content={{ title, description }}>
  <!-- Page Header -->
  <div class="page-header">
    <h1 class="page-title font-display">全部文章</h1>
  </div>

  <!-- Category Filter -->
  <div class="category-filter">
    <a href="/blog" class:list={["filter-item", !Astro.url.searchParams.get('tag') && "filter-active"]}>
      全部
    </a>
    {uniqueCategories.map(category => (
      <a href={`/tags/${category}`} class="filter-item">{category}</a>
    ))}
  </div>

  <!-- Featured Post (first page only) -->
  {page.currentPage === 1 && posts.length > 0 && (
    <section class="mb-8">
      <PostPreview post={posts[0]} featured={true} />
    </section>
  )}

  <!-- Posts List -->
  <section class="posts-section">
    <PostPreviewList
      posts={page.currentPage === 1 ? posts.slice(1) : posts}
      mode="row"
      heading={page.currentPage === 1 ? "近期文章" : undefined}
    />
  </section>

  <!-- Pagination -->
  <div class="pagination-wrapper">
    <Paginator page={page} />
  </div>
</DefaultPageLayout>

<style>
  .page-header {
    @apply pt-8 pb-8 md:pt-12 md:pb-10;
  }

  .page-title {
    @apply text-3xl md:text-4xl;
    @apply text-theme-text-primary;
    letter-spacing: -0.02em;
  }

  :global(html.dark) .page-title {
    @apply text-theme-dark-text-primary;
  }

  /* Category Filter */
  .category-filter {
    @apply flex flex-wrap gap-2 md:gap-3;
    @apply pb-6 mb-2;
    @apply border-b;
    border-color: theme('colors.theme.border');
  }

  :global(html.dark) .category-filter {
    border-color: theme('colors.theme.dark-border');
  }

  .filter-item {
    @apply text-xs md:text-sm;
    @apply text-theme-text-muted;
    @apply transition-colors duration-200;
    text-decoration: none;
  }

  .filter-item:hover {
    @apply text-blue-500;
  }

  :global(html.dark) .filter-item {
    @apply text-theme-dark-text-muted;
  }

  :global(html.dark) .filter-item:hover {
    @apply text-blue-400;
  }

  .filter-active {
    @apply text-theme-text-primary font-medium;
  }

  :global(html.dark) .filter-active {
    @apply text-theme-dark-text-primary;
  }

  .posts-section {
    @apply pb-4;
  }

  .pagination-wrapper {
    @apply py-10;
    @apply flex justify-center;
    @apply border-t;
    border-color: theme('colors.theme.border');
  }

  :global(html.dark) .pagination-wrapper {
    border-color: theme('colors.theme.dark-border');
  }
</style>
