---
export const prerender = true;

import { getCollection } from "astro:content";
import DefaultPageLayout from "$/layouts/default.astro";
import Code from "$/components/Code.astro";
import Prose from "$/components/Prose.astro";
import config from "$/config/config.json";

const title = "Home";
const description = "Daily News Report - 你的每日科技新闻精选";
const aiModel = config.aiprovider_model || "";

let posts = await getCollection("blog");
posts = posts.toSorted(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
);

const formatDateKey = (dateValue: Date | string) =>
  new Intl.DateTimeFormat("en-CA", {
    timeZone: "Asia/Shanghai",
    year: "numeric",
    month: "2-digit",
    day: "2-digit",
  }).format(new Date(dateValue));

const todayKey = formatDateKey(new Date());
const todayPost =
  posts.find((post) => formatDateKey(post.data.date) === todayKey) ?? posts[0];
const todayRendered = todayPost ? await todayPost.render() : undefined;
const TodayContent = todayRendered?.Content;

// Recent posts for listing
const recentPosts = posts.filter(p => p.slug !== todayPost?.slug).slice(0, 8);
---

<DefaultPageLayout content={{ title, description }} showPageHeader={false}>
  <!-- Date line -->
  <div class="dateline">
    {new Date().toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
    {aiModel && (
      <>
        <span class="dateline-sep">&middot;</span>
        <span class="dateline-ai">AI generated with {aiModel}</span>
      </>
    )}
  </div>

  <!-- Today's Featured -->
  {todayPost ? (
    <section class="featured">
      <a href={`/blog/${todayPost.slug}`} class="featured-link">
        <h1 class="featured-title font-display">{todayPost.data.title}</h1>
      </a>
      {todayPost.data.description && (
        <p class="featured-desc">{todayPost.data.description}</p>
      )}
      <div class="featured-tags">
        {(todayPost.data.tags || []).slice(0, 4).map((tag) => (
          <span class="featured-tag">{tag}</span>
        ))}
      </div>

      <!-- Today's Content -->
      <div class="today-content">
        <Prose showNavigation={false} showComment={false}>
          {TodayContent && <TodayContent components={{ code: Code }} />}
        </Prose>
      </div>
    </section>
  ) : (
    <div class="empty-state">暂无可展示的文章内容</div>
  )}

  <!-- Divider -->
  <div class="section-divider"></div>

  <!-- Recent Posts -->
  {recentPosts.length > 0 && (
    <section class="recent">
      <div class="recent-list">
        {recentPosts.map((post) => {
          const postDate = new Date(post.data.date);
          const dateStr = postDate.toLocaleDateString('zh-CN', { month: 'short', day: 'numeric' });
          return (
            <a href={`/blog/${post.slug}`} class="recent-item">
              <div class="recent-left">
                <h3 class="recent-title font-display">{post.data.title}</h3>
                {post.data.description && (
                  <p class="recent-desc">{post.data.description}</p>
                )}
              </div>
              <div class="recent-right">
                <span class="recent-date">{dateStr}</span>
                <span class="recent-arrow">&rarr;</span>
              </div>
            </a>
          );
        })}
      </div>
    </section>
  )}

  <!-- More Link -->
  <div class="more-link">
    <a href="/blog">查看全部文章 &rarr;</a>
  </div>
</DefaultPageLayout>

<style>
  .dateline {
    @apply pt-4 pb-10 md:pb-14;
    @apply text-xs md:text-sm;
    @apply text-theme-text-muted;
    letter-spacing: 0.08em;
  }

  :global(html.dark) .dateline {
    @apply text-theme-dark-text-muted;
  }

  .dateline-sep {
    @apply mx-2;
  }

  .dateline-ai {
    @apply text-[10px] md:text-xs;
    opacity: 0.6;
  }

  /* Featured */
  .featured {
    @apply pb-10 md:pb-14;
  }

  .featured-link {
    text-decoration: none;
  }

  .featured-title {
    @apply text-3xl md:text-5xl lg:text-6xl;
    @apply font-bold;
    @apply text-theme-text-primary;
    @apply leading-tight;
    @apply transition-colors duration-200;
    letter-spacing: -0.025em;
    max-width: 28ch;
  }

  :global(html.dark) .featured-title {
    @apply text-theme-dark-text-primary;
  }

  .featured-link:hover .featured-title {
    @apply text-blue-500;
  }

  :global(html.dark) .featured-link:hover .featured-title {
    @apply text-blue-400;
  }

  .featured-desc {
    @apply text-base md:text-lg;
    @apply text-theme-text-secondary;
    @apply mt-4 md:mt-6;
    @apply max-w-2xl;
    @apply leading-relaxed;
  }

  :global(html.dark) .featured-desc {
    @apply text-theme-dark-text-secondary;
  }

  .featured-tags {
    @apply flex flex-wrap gap-3 mt-4;
  }

  .featured-tag {
    @apply text-xs;
    @apply text-theme-text-secondary;
    letter-spacing: 0.05em;
  }

  :global(html.dark) .featured-tag {
    @apply text-theme-dark-text-muted;
  }

  .today-content {
    @apply mt-10;
    @apply border-t;
    border-color: theme('colors.theme.border');
    @apply pt-8;
  }

  :global(html.dark) .today-content {
    border-color: theme('colors.theme.dark-border');
  }

  .today-content :global(article.prose) {
    margin-top: 0;
  }

  .today-content :global(article.prose > *:first-child) {
    margin-top: 0 !important;
    padding-top: 0 !important;
  }

  .empty-state {
    @apply py-20 text-center text-theme-text-muted;
    font-style: italic;
  }

  :global(html.dark) .empty-state {
    @apply text-theme-dark-text-muted;
  }

  /* Divider */
  .section-divider {
    @apply pb-px;
    background: theme('colors.theme.border');
  }

  :global(html.dark) .section-divider {
    background: theme('colors.theme.dark-border');
  }

  /* Recent Posts */
  .recent {
    @apply py-10 md:py-14;
  }

  .recent-list {
    @apply flex flex-col;
  }

  .recent-item {
    @apply flex items-start justify-between gap-4;
    @apply py-5 md:py-6;
    @apply border-b;
    @apply transition-all duration-200;
    border-color: theme('colors.theme.border');
    text-decoration: none;
  }

  :global(html.dark) .recent-item {
    border-color: theme('colors.theme.dark-border');
  }

  .recent-item:last-child {
    @apply border-b-0;
  }

  .recent-item:hover {
    padding-left: 6px;
  }

  .recent-left {
    @apply flex-1 min-w-0;
  }

  .recent-title {
    @apply text-lg md:text-xl lg:text-2xl;
    @apply font-semibold;
    @apply text-theme-text-primary;
    @apply leading-snug;
    @apply transition-colors duration-200;
  }

  :global(html.dark) .recent-title {
    @apply text-theme-dark-text-primary;
  }

  .recent-item:hover .recent-title {
    @apply text-blue-500;
  }

  :global(html.dark) .recent-item:hover .recent-title {
    @apply text-blue-400;
  }

  .recent-desc {
    @apply text-sm text-theme-text-secondary mt-1.5;
    @apply line-clamp-1;
  }

  :global(html.dark) .recent-desc {
    @apply text-theme-dark-text-secondary;
  }

  .recent-right {
    @apply flex items-center gap-3 flex-shrink-0;
    @apply pt-1;
  }

  .recent-date {
    @apply text-xs text-theme-text-muted;
    white-space: nowrap;
  }

  :global(html.dark) .recent-date {
    @apply text-theme-dark-text-muted;
  }

  .recent-arrow {
    @apply text-xs text-theme-text-muted;
    @apply opacity-0 transition-all duration-200;
  }

  :global(html.dark) .recent-arrow {
    @apply text-theme-dark-text-muted;
  }

  .recent-item:hover .recent-arrow {
    @apply opacity-100 text-blue-500;
    transform: translateX(3px);
  }

  :global(html.dark) .recent-item:hover .recent-arrow {
    @apply text-blue-400;
  }

  /* More Link */
  .more-link {
    @apply pb-12 md:pb-16;
    @apply text-sm;
  }

  .more-link a {
    @apply text-theme-text-muted;
    @apply transition-colors duration-200;
    text-decoration: none;
  }

  .more-link a:hover {
    @apply text-blue-500;
  }

  :global(html.dark) .more-link a {
    @apply text-theme-dark-text-muted;
  }

  :global(html.dark) .more-link a:hover {
    @apply text-blue-400;
  }

  @media (max-width: 640px) {
    .featured-title {
      @apply text-2xl;
    }
    .recent-title {
      @apply text-base;
    }
    .recent-desc {
      @apply hidden;
    }
  }
</style>
