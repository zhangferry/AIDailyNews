---
export const prerender = true;

import { getCollection } from "astro:content";
import DefaultPageLayout from "$/layouts/default.astro";
import GeneratedCover from "$/components/GeneratedCover.astro";
import Code from "$/components/Code.astro";
import Prose from "$/components/Prose.astro";

const title = "Home";
const description =
  "Daily News Report - Your daily dose of tech and development news";

let posts = await getCollection("blog");
posts = posts.toSorted(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
);

const formatDateKey = (dateValue: Date | string) =>
  new Intl.DateTimeFormat("en-CA", {
    timeZone: "Asia/Shanghai",
    year: "numeric",
    month: "2-digit",
    day: "2-digit",
  }).format(new Date(dateValue));

const todayKey = formatDateKey(new Date());
const todayPost =
  posts.find((post) => formatDateKey(post.data.date) === todayKey) ?? posts[0];
const uniqueCategories = [...new Set(todayPost?.data.tags || [])];
const todayRendered = todayPost ? await todayPost.render() : undefined;
const coverHeadings = (todayRendered?.headings || [])
  .map((heading) => heading.text)
  .slice(0, 5);
const TodayContent = todayRendered?.Content;
---

<DefaultPageLayout content={{ title, description }} showPageHeader={false}>
  <!-- Hero Section with Featured Article -->
  <section class="hero-section">
    <div class="hero-content">
      <p class="hero-description">你的每日科技新闻精选，AI 驱动的智能聚合</p>
    </div>

    <!-- Category Pills -->
    <div class="category-pills">
      {
        uniqueCategories.map((category) => (
          <a href={`/tags/${category}`} class="category-pill">
            {category}
          </a>
        ))
      }
    </div>
  </section>

  <section class="today-post-section">
    {
      todayPost ? (
        <>
          <div class="today-post-cover">
            {todayPost.data.image ? (
              <img
                src={todayPost.data.image}
                alt={todayPost.data.title}
                class="today-post-cover-image"
                loading="lazy"
              />
            ) : (
              <GeneratedCover
                title={todayPost.data.title}
                slug={todayPost.slug}
                tags={todayPost.data.tags}
                date={todayPost.data.date}
                headings={coverHeadings}
                width={1200}
                height={500}
                class="today-post-cover-image"
                alt={todayPost.data.title}
              />
            )}
          </div>

          <div class="today-content-wrap">
            <Prose showNavigation={false} showComment={false}>
              {TodayContent && <TodayContent components={{ code: Code }} />}
            </Prose>
          </div>
        </>
      ) : (
        <div class="today-empty">暂无可展示的文章内容</div>
      )
    }
  </section>

  <section class="cta-section">
    <div class="cta-content">
      <h2 class="cta-title font-display font-bold">Stay Updated</h2>
      <p class="cta-description">
        Get the latest tech news delivered to your inbox daily
      </p>
      <div class="cta-actions">
        <a href="/blog" class="cta-button cta-button-primary">
          Browse All Posts
        </a>
        <a href="/tags" class="cta-button cta-button-secondary">
          Explore by Topic
        </a>
      </div>
    </div>
  </section>
</DefaultPageLayout>

<style>
  /* Hero Section */
  .hero-section {
    @apply py-6 md:py-8 lg:py-10;
    @apply text-center;
    @apply relative overflow-hidden;
  }

  .hero-section::before {
    content: "";
    @apply absolute inset-0;
    background: radial-gradient(
      ellipse at center,
      rgba(91, 124, 153, 0.08) 0%,
      transparent 70%
    );
    @apply pointer-events-none;
  }

  :global(html.dark) .hero-section::before {
    background: radial-gradient(
      ellipse at center,
      rgba(107, 184, 184, 0.1) 0%,
      transparent 70%
    );
  }

  .hero-content {
    @apply relative z-10;
  }

  .hero-description {
    @apply text-lg md:text-xl text-theme-text-secondary;
    @apply max-w-2xl mx-auto;
    @apply mt-0;
  }

  /* Category Pills */
  .category-pills {
    @apply flex flex-wrap justify-center gap-3;
    @apply mt-4;
  }

  .category-pill {
    @apply px-4 py-2 rounded-full;
    @apply text-sm font-medium;
    @apply bg-theme-surface border border-theme-border;
    @apply text-theme-text-secondary;
    @apply transition-all duration-200 ease-out;
    @apply hover:border-theme-primary hover:text-theme-primary hover:bg-theme-primary/10;
  }

  :global(html.dark) .category-pill {
    @apply bg-theme-dark-surface border-theme-dark-border text-theme-dark-text-secondary;
    @apply hover:border-theme-dark-primary hover:text-theme-dark-primary hover:bg-theme-dark-primary/10;
  }

  .today-post-section {
    @apply pt-0 pb-2 md:pb-3;
  }

  .today-post-cover {
    @apply relative overflow-hidden rounded-xl mb-1 md:mb-2;
    aspect-ratio: 21 / 8;
  }

  .today-post-cover-image {
    @apply block w-full h-full object-cover object-center;
  }

  .today-content-wrap :global(article.prose) {
    margin-top: 0;
  }

  .today-content-wrap :global(article.prose > *:first-child) {
    margin-top: 0 !important;
    padding-top: 0 !important;
  }

  .today-empty {
    @apply py-10 text-center text-theme-text-muted;
  }

  :global(html.dark) .today-empty {
    @apply text-theme-dark-text-muted;
  }

  /* CTA Section */
  .cta-section {
    @apply py-16 md:py-24;
    @apply mt-12;
    @apply relative;
    @apply overflow-hidden;
    @apply rounded-2xl;
    background: linear-gradient(
      135deg,
      rgba(91, 124, 153, 0.1) 0%,
      rgba(107, 184, 184, 0.1) 100%
    );
    border: 1px solid rgba(91, 124, 153, 0.2);
  }

  :global(html.dark) .cta-section {
    background: linear-gradient(
      135deg,
      rgba(107, 184, 184, 0.12) 0%,
      rgba(212, 165, 165, 0.12) 100%
    );
    border: 1px solid rgba(107, 184, 184, 0.25);
  }

  .cta-content {
    @apply text-center px-6;
    @apply relative z-10;
  }

  .cta-title {
    @apply text-3xl md:text-4xl lg:text-5xl;
    @apply text-theme-text-primary;
    @apply mb-4;
  }

  :global(html.dark) .cta-title {
    @apply text-theme-dark-text-primary;
  }

  .cta-description {
    @apply text-lg text-theme-text-secondary;
    @apply max-w-xl mx-auto;
    @apply mb-8;
  }

  :global(html.dark) .cta-description {
    @apply text-theme-dark-text-secondary;
  }

  .cta-actions {
    @apply flex flex-wrap justify-center gap-4;
  }

  .cta-button {
    @apply px-6 py-3 rounded-full;
    @apply font-semibold;
    @apply transition-all duration-200 ease-out;
    @apply inline-flex items-center gap-2;
  }

  .cta-button-primary {
    @apply bg-theme-primary text-black;
    @apply hover:bg-theme-primary/90 hover:shadow-lg;
    @apply hover:-translate-y-0.5;
  }

  :global(html.dark) .cta-button-primary {
    @apply bg-theme-dark-primary hover:bg-theme-dark-primary/90;
  }

  .cta-button-secondary {
    @apply bg-theme-surface border border-theme-border text-theme-text-primary;
    @apply hover:border-theme-primary hover:text-theme-primary;
    @apply hover:bg-theme-primary/10;
  }

  :global(html.dark) .cta-button-secondary {
    @apply bg-theme-dark-surface border-theme-dark-border text-theme-dark-text-primary;
    @apply hover:border-theme-dark-primary hover:text-theme-dark-primary;
    @apply hover:bg-theme-dark-primary/10;
  }
</style>
