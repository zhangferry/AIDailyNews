---
import { SITE } from "$/config";
import { NAV_ITEMS } from "$/config";
import { toTitleCase } from "$/utils";
import SvgIcon from "./SvgIcon.astro";
import ModeSwitcherBtn from "./ModeSwitcherBtn.svelte";
import SearchBtn from "./SearchBtn.svelte";
---

<header class="site-header">
  <div class="header-inner">
    <!-- Left: Brand -->
    <a href="/" class="brand">
      <span class="brand-name">Daily News Report</span>
    </a>

    <!-- Center: Navigation -->
    <nav class="header-nav">
      {Object.keys(NAV_ITEMS).map((navItemKey, index) => (
        <>
          {index > 0 && <span class="nav-sep">/</span>}
          <a
            class:list={[
              "nav-link",
              Astro.url.pathname === NAV_ITEMS[navItemKey].path ? "nav-link-active" : "",
            ]}
            href={NAV_ITEMS[navItemKey].path}
          >
            {toTitleCase(NAV_ITEMS[navItemKey].title)}
          </a>
        </>
      ))}
    </nav>

    <!-- Right: Actions -->
    <div class="header-actions">
      <SearchBtn client:visible />
      <a href={SITE.githubUrl} title="GitHub" class="action-btn" aria-label="GitHub">
        <SvgIcon>
          <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path>
        </SvgIcon>
      </a>
      <a href="/rss.xml" title="RSS" class="action-btn" aria-label="RSS">
        <SvgIcon>
          <path d="M4 11a9 9 0 0 1 9 9"></path>
          <path d="M4 4a16 16 0 0 1 16 16"></path>
          <circle cx="5" cy="19" r="1"></circle>
        </SvgIcon>
      </a>
      <div class="action-btn">
        <ModeSwitcherBtn client:visible />
      </div>
    </div>
  </div>
</header>

<style>
  .site-header {
    @apply py-6 md:py-8;
  }

  .header-inner {
    @apply flex items-center justify-between;
  }

  .brand {
    text-decoration: none;
  }

  .brand-name {
    @apply text-sm md:text-base font-medium tracking-wide;
    @apply text-theme-text-primary;
  }

  :global(html.dark) .brand-name {
    @apply text-theme-dark-text-primary;
  }

  .header-nav {
    @apply flex items-center gap-3;
  }

  .nav-sep {
    @apply text-theme-text-muted text-xs;
  }

  :global(html.dark) .nav-sep {
    @apply text-theme-dark-text-muted;
  }

  .nav-link {
    @apply text-sm;
    @apply text-theme-text-muted;
    @apply transition-colors duration-200;
    text-decoration: none;
  }

  .nav-link:hover {
    @apply text-blue-500;
  }

  :global(html.dark) .nav-link {
    @apply text-theme-dark-text-muted;
  }

  :global(html.dark) .nav-link:hover {
    @apply text-blue-400;
  }

  .nav-link-active {
    @apply text-theme-text-primary font-medium;
  }

  :global(html.dark) .nav-link-active {
    @apply text-theme-dark-text-primary;
  }

  .header-actions {
    @apply flex items-center gap-1;
  }

  .action-btn {
    @apply flex items-center justify-center;
    @apply w-8 h-8;
    @apply text-theme-text-muted;
    @apply transition-colors duration-200;
    @apply hover:text-blue-500;
    cursor: pointer;
    text-decoration: none;
  }

  :global(html.dark) .action-btn {
    @apply text-theme-dark-text-muted;
    @apply hover:text-blue-400;
  }

  .action-btn svg {
    @apply w-4 h-4;
  }

  @media (max-width: 640px) {
    .brand-name {
      @apply text-xs;
    }
    .nav-link {
      @apply text-xs;
    }
    .header-nav {
      @apply gap-2;
    }
  }
</style>
