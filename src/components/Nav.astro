---
import { toTitleCase } from "$/utils";
import { NAV_ITEMS } from "$/config";
---

<nav class="nav py-3">
  <ul class="nav-list" transition:animate="fade">
    {
      Object.keys(NAV_ITEMS).map((navItemKey) => (
        <li>
          <a
            class:list={[
              `pb-1 border-b-2 hover:border-theme-text-muted`,
              Astro.url.pathname !== NAV_ITEMS[navItemKey].path
                ? "border-theme-border"
                : "",
              Astro.url.pathname === NAV_ITEMS[navItemKey].path
                ? "border-theme-primary"
                : "",
            ]}
            href={NAV_ITEMS[navItemKey].path}
            title={NAV_ITEMS[navItemKey].title}
          >
            {toTitleCase(NAV_ITEMS[navItemKey].title)}
          </a>
        </li>
      ))
    }
  </ul>
</nav>
<style>
  .nav-list {
    @apply inline-flex list-none gap-8 text-xl font-semibold text-theme-primary py-2 flex-wrap;
  }
  :global(html.dark) .nav-list {
    @apply text-theme-dark-primary;
  }
  :global(html.dark) .nav-list a {
    @apply hover:border-theme-dark-text-muted;
  }
  :global(html.dark) .nav-list a:not(.border-theme-primary) {
    @apply border-theme-dark-border;
  }
</style>
