---
import type { CollectionEntry } from "astro:content";
import PostPreview from "./PostPreview.astro";

interface Props {
  posts: CollectionEntry<"blog">[];
  heading?: string;
  mode?: "row" | "col";
  showFeatured?: boolean;
  featuredCount?: number;
}

const {
  posts,
  heading,
  mode = "col",
  showFeatured = false,
  featuredCount = 1,
} = Astro.props;

const sortedPosts = posts.toSorted(
  (a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf()
);

// Split posts into featured and regular
const featuredPosts = showFeatured ? sortedPosts.slice(0, featuredCount) : [];
const regularPosts = showFeatured ? sortedPosts.slice(featuredCount) : sortedPosts;
---

<section class="post-preview-section">
  {
    heading && (
      <div class="section-header mb-8">
        <h2 class="section-title ink-h">{heading}</h2>
        <div class="section-border"></div>
      </div>
    )
  }

  <!-- Featured Articles -->
  {
    showFeatured && featuredPosts.length > 0 && (
      <div class="featured-section mb-12">
        {featuredPosts.map((post, index) => (
          <PostPreview
            post={post}
            featured={true}
          />
        ))}
      </div>
    )
  }

  <!-- Regular Articles Grid/List -->
  <div class={`post-preview__list post-preview__list--${mode}`}>
    {
      regularPosts.map((post, index) => (
        <PostPreview
          post={post}
          asCard={mode === "row"}
          class={`animate-fade-in-up stagger-${Math.min(index + 1, 5)}`}
        />
      ))
    }
  </div>
</section>

<style>
  .post-preview-section {
    @apply relative;
  }

  .section-header {
    @apply relative;
  }

  .section-title {
    @apply text-lg md:text-xl font-display font-bold;
    @apply text-theme-text-primary;
    @apply mb-0;
  }

  :global(html.dark) .section-title {
    @apply text-theme-dark-text-primary;
  }

  .section-border {
    @apply h-px bg-gradient-to-r from-theme-border via-theme-primary/50 to-transparent;
    @apply mt-4;
  }

  :global(html.dark) .section-border {
    @apply from-theme-dark-border via-theme-dark-primary/50;
  }

  .featured-section {
    @apply relative;
  }

  .post-preview__list {
    @apply flex;
  }

  .post-preview__list--col {
    @apply flex-col gap-6;
  }

  .post-preview__list--row {
    @apply flex-row flex-wrap gap-6;
    @apply -mx-3 px-3;
  }

  .post-preview__list--row .post-preview {
    @apply w-full sm:w-1/2 lg:w-1/3;
  }

  /* Ensure animations work properly */
  .animate-fade-in-up {
    opacity: 0;
    animation-fill-mode: forwards;
  }
</style>
